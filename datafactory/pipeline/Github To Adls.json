{
	"name": "Github To Adls",
	"properties": {
		"activities": [
			{
				"name": "git to bronze",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"requestMethod": "GET"
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "git_source_ds",
						"type": "DatasetReference",
						"parameters": {
							"filename": "sales_teams.csv"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "adls_dest_ds",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "Email_alert_for_success",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "git to bronze",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"url": "https://prod-33.eastus2.logic.azure.com:443/workflows/fc34a1b4b8894df49e8d995b71f5fc4a/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=NIPV189Nz6qmxbueR40a0x6aQ1Gfxa-KUYcnIFFSJsA",
					"body": {
						"value": "{\n    \"PipelineName\":\"@{pipeline().Pipeline}\",\n    \"Status\":\"Succeded\",\n    \"RunId\":\"@{pipeline().RunId}\",\n    \"Time\": \"@{utcNow()}\"\n}",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Email_alert_for_failure",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "git to bronze",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"url": "https://prod-33.eastus2.logic.azure.com:443/workflows/fc34a1b4b8894df49e8d995b71f5fc4a/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=NIPV189Nz6qmxbueR40a0x6aQ1Gfxa-KUYcnIFFSJsA",
					"body": {
						"value": "{\n    \"PipelineName\":\"@{pipeline().Pipeline}\",\n    \"Status\":\"Failed\",\n    \"RunId\":\"@{pipeline().RunId}\",\n    \"Time\":\"@{utcNow()}\"\n}",
						"type": "Expression"
					}
				}
			}
		],
		"annotations": []
	}
}