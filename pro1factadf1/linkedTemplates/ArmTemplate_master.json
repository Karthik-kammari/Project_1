{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "pro1factadf1"
		},
		"adls_bronze_ls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adls_bronze_ls'"
		},
		"localfile_ls_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'localfile_ls'"
		},
		"adls_bronze_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://karthikdata1.dfs.core.windows.net/"
		},
		"localfile_ls_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "C:\\Users\\karth\\Desktop\\Project_1"
		},
		"localfile_ls_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "karthikchary64@gmail.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "pro1factadf1_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"adls_bronze_ls_accountKey": {
						"value": "[parameters('adls_bronze_ls_accountKey')]"
					},
					"localfile_ls_password": {
						"value": "[parameters('localfile_ls_password')]"
					},
					"adls_bronze_ls_properties_typeProperties_url": {
						"value": "[parameters('adls_bronze_ls_properties_typeProperties_url')]"
					},
					"localfile_ls_properties_typeProperties_host": {
						"value": "[parameters('localfile_ls_properties_typeProperties_host')]"
					},
					"localfile_ls_properties_typeProperties_userId": {
						"value": "[parameters('localfile_ls_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}